# Rainforest API — https://rainforestapi.com (used for discovery only)
# ScraperAPI — https://scraperapi.com (used for competitor discovery)
SCRAPER_API_KEY=your_scraperapi_key_here

# Review scraping uses amazon.in AJAX + session cookies (no API key needed)
# Run: bun run test/login-amazon-in.ts to save cookies

# Anthropic Claude API — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Azure Blob Storage — Azure Portal → Storage Account → Access Keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=review-analytics

# Resend — https://resend.com (free tier: 3,000 emails/month, no domain verification needed for testing)
RESEND_API_KEY=re_your_resend_api_key_here
# Optional: sender address — leave blank to use onboarding@resend.dev
REPORT_EMAIL_FROM=

# Target product
TARGET_ASIN=B0XXXXXXXX
AMAZON_CATEGORY=electronics
AMAZON_DOMAIN=amazon.in

# Optional: override BSR constant C for your category (from Jungle Scout web tool)
# BSR_CONSTANT_OVERRIDE=185000

# Local settings
DB_PATH=./data/reviews.db
MAX_REVIEWS_PER_LISTING=1000
